{
  "name": "sh3-ai",
  "version": "0.7.0",
  "description": "Abstract AI-chat shard for SH3: owns the `ai` shell mode, the `ai:*` verbs, and the sh3-ai.provider contribution point",
  "author": "@unfinished-lair",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./contributions": {
      "types": "./dist/contributions.d.ts",
      "default": "./dist/contributions.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "build:artifact": "vite build --config vite.artifact.ts",
    "dev": "vite build --watch",
    "test": "vitest run"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "marked": "^15.0.0",
    "sh3-core": "^0.23.2",
    "svelte": "^5.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
