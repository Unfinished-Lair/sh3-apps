{
  "name": "sh3-editor",
  "version": "0.1.1",
  "description": "Reusable text editor shard for SH3",
  "author": "@unfinished-lair",
  "type": "module",
  "types": "dist/types.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types.d.ts"
    }
  },
  "files": ["dist/types.d.ts"],
  "scripts": {
    "build": "tsc -p tsconfig.types.json",
    "build:artifact": "vite build --config vite.artifact.ts",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "sh3-core": "^0.7.1"
  },
  "devDependencies": {
    "sh3-core": "^0.7.1",
    "svelte": "^5.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0"
  }
}
