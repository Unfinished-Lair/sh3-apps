{
  "name": "@unfinished-lair/sh3-editor",
  "version": "0.6.2",
  "description": "Reusable text editor and object inspector shard for SH3",
  "author": "@unfinished-lair",
  "type": "module",
  "types": "dist/types.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types.d.ts"
    },
    "./inspector/contributions": {
      "types": "./dist/inspector/contributions.d.ts",
      "import": "./dist/inspector/contributions.js",
      "default": "./dist/inspector/contributions.js"
    },
    "./settings/contributions": {
      "types": "./dist/settings/contributions.d.ts",
      "import": "./dist/settings/contributions.js",
      "default": "./dist/settings/contributions.js"
    },
    "./help/contributions": {
      "types": "./dist/help/contributions.d.ts",
      "import": "./dist/help/contributions.js",
      "default": "./dist/help/contributions.js"
    }
  },
  "files": [
    "dist/types.d.ts",
    "dist/inspector/contributions.d.ts",
    "dist/inspector/contributions.js",
    "dist/settings/contributions.d.ts",
    "dist/settings/contributions.js",
    "dist/help/contributions.d.ts",
    "dist/help/contributions.js"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.types.json && tsc -p tsconfig.runtime.json",
    "build:artifact": "vite build --config vite.artifact.ts",
    "dev": "vite build --watch",
    "test": "vitest run"
  },
  "peerDependencies": {
    "sh3-core": "^0.11.4"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "sh3-core": "^0.11.4",
    "svelte": "^5.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
