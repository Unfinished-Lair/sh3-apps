{
  "name": "@unfinished-lair/sh3-editor",
  "version": "0.3.0",
  "description": "Reusable text editor and object inspector shard for SH3",
  "author": "@unfinished-lair",
  "type": "module",
  "types": "dist/types.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types.d.ts"
    },
    "./inspector/contributions": {
      "types": "./dist/inspector/contributions.d.ts"
    }
  },
  "files": [
    "dist/types.d.ts",
    "dist/inspector/contributions.d.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.types.json",
    "build:artifact": "vite build --config vite.artifact.ts",
    "dev": "vite build --watch",
    "test": "vitest run"
  },
  "peerDependencies": {
    "sh3-core": "^0.10.4"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "sh3-core": "^0.10.4",
    "svelte": "^5.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
