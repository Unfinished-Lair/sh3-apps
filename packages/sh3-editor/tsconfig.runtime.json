{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": false,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "Bundler",
    "isolatedModules": true
  },
  "include": ["src/inspector/contributions.ts"],
  "exclude": ["**/*.svelte", "**/*.test.ts"]
}
