{
  "name": "sh3-file-explorer",
  "version": "0.4.1",
  "description": "Official SH3 file explorer — browse tenant documents",
  "author": "@unfinished-lair",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "build:artifact": "vite build --config vite.artifact.ts",
    "dev": "vite build --watch",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "sh3-core": "^0.10.1"
  },
  "devDependencies": {
    "sh3-core": "^0.10.1",
    "svelte": "^5.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0"
  }
}
